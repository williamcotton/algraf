Algraf(version: "0.20")

Chart(data: "heatmap.csv", width: 700, height: 460, title: "Custom continuous gradient") {
    Scale(
        fill: value,
        gradient: [
            Stop(value: 3, color: "rgba(51, 102, 204, 1)"),
            Stop(value: 7, color: "rgb(80, 120, 160)"),
            Stop(value: 10, color: "#cc3333ff"),
        ],
        label: "Intensity",
    )

    Space(day * hour) {
        Tile(fill: value, alpha: 0.92)
    }
}
