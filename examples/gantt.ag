Chart(data: "gantt.csv", width: 760, height: 420, title: "Project Schedule") {
    Theme(name: "classic")

    Guide(axis: x, label: "Timeline")
    Guide(axis: y, label: "Attorney / phase")

    Space((start_date + end_date) * (attorney / phase)) {
        Rect(
            xmin: start_date,
            xmax: end_date,
            ymin: phase,
            ymax: phase,
            fill: phase,
            alpha: 0.85,
        )
    }
}
