Chart(data: Parquet("../../data/generated/algraf-large-fixtures/current/dense_points.parquet"),
      width: 780, height: 500,
      title: "Raw dense points should require an explicit budget") {
    Theme(name: "minimal")

    Space(x * y) {
        Point(fill: group, alpha: 0.22, size: 1.8)
    }
}
